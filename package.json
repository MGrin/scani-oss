{
  "name": "scani",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/backend",
    "apps/frontendV2",
    "apps/landing",
    "packages/*"
  ],
  "scripts": {
    "check-env": "bun run scripts/check-env.ts",
    "dev": "concurrently \"cd apps/backend && bun dev\" \"cd apps/frontendV2 && bun dev\" \"cd apps/landing && bun dev\"",
    "dev:backend": "cd apps/backend && bun dev",
    "dev:frontend": "cd apps/frontendV2 && bun dev",
    "dev:landing": "cd apps/landing && bun dev",
    "dev:mobile:ios": "cd apps/mobile && bun ios",
    "dev:mobile:android": "cd apps/mobile && bun ios",
    "build": "bun run build:backend && bun run build:frontendV2",
    "build:backend": "cd apps/backend && bun run build",
    "build:frontend": "cd apps/frontendV2 && bun run build",
    "clean": "cd apps/backend && bun clean && cd ../frontendV2 && bun clean",
    "type-check": "cd apps/backend && bun type-check && cd ../frontendV2 && bun type-check",
    "test": "bun test",
    "test:shared": "cd packages/shared && bun test",
    "test:backend": "cd apps/backend && bun test",
    "test:frontend": "cd apps/frontendV2 && bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:coverage:html": "bun test --coverage --coverage-reporter=html",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/bun": "latest",
    "concurrently": "^8.2.2",
    "typescript": "^5"
  },
  "dependencies": {
  }
}
