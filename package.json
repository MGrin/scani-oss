{
  "name": "scani",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check-env": "bun run scripts/check-env.ts",
    "dev": "concurrently \"cd apps/backend && bun dev\" \"cd apps/frontend && bun dev\"",
    "dev:backend": "cd apps/backend && bun dev",
    "dev:frontend": "cd apps/frontend && bun dev",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "cd apps/backend && bun run build",
    "build:frontend": "cd apps/frontend && bun run build",
    "clean": "cd apps/backend && bun clean && cd ../frontend && bun clean",
    "type-check": "cd apps/backend && bun type-check && cd ../frontend && bun type-check",
    "test": "bun test",
    "test:shared": "cd packages/shared && bun test",
    "test:backend": "cd apps/backend && bun test",
    "test:frontend": "cd apps/frontend && bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:coverage:html": "bun test --coverage --coverage-reporter=html",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bun": "latest",
    "concurrently": "^8.2.2",
    "msw": "^2.4.9",
    "sharp": "^0.34.4",
    "typescript": "^5"
  }
}
