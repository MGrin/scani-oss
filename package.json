{
  "name": "scani",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/backend",
    "apps/cron",
    "apps/frontendV2",
    "apps/landing",
    "apps/worker",
    "packages/*"
  ],
  "scripts": {
    "prepare": "git config --local core.hooksPath .githooks || true",
    "db:migrate": "cd packages/core && bun db:migrate",
    "deps:lint": "syncpack lint",
    "deps:fix": "syncpack fix",
    "deps:unused": "knip --dependencies",
    "deps:outdated": "syncpack update --check",
    "deps:update:minor": "syncpack update --target minor",
    "dev": "concurrently \"bun dev:backend\" \"bun dev:frontend\"",
    "dev:backend": "cd apps/backend && bun dev",
    "dev:cron": "cd apps/cron && bun dev",
    "dev:frontend": "cd apps/frontendV2 && bun dev",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "cd apps/backend && bun run build",
    "build:frontend": "cd apps/frontendV2 && bun run build",
    "clean": "cd apps/backend && bun clean && cd ../frontendV2 && bun clean",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:backend": "cd apps/backend && bun run lint",
    "lint:cron": "cd apps/cron && bun run lint",
    "lint:frontend": "cd apps/frontendV2 && bun run lint",
    "lint:shared": "cd packages/shared && bun run lint",
    "lint:core": "cd packages/core && bun run lint",
    "lint:integrations": "cd packages/integrations && bun run lint",
    "type-check": "concurrently \"bun run type-check:backend\" \"bun run type-check:worker\" \"bun run type-check:cron\" \"bun run type-check:frontend\" \"bun run type-check:landing\" \"bun run type-check:shared\" \"bun run type-check:core\" \"bun run type-check:integrations\"",
    "type-check:backend": "cd apps/backend && bun run type-check",
    "type-check:worker": "cd apps/worker && bun run type-check",
    "type-check:cron": "cd apps/cron && bun run type-check",
    "type-check:frontend": "cd apps/frontendV2 && bun run type-check",
    "type-check:landing": "cd apps/landing && bun run type-check",
    "type-check:shared": "cd packages/shared && bun run type-check",
    "type-check:core": "cd packages/core && bun run type-check",
    "type-check:integrations": "cd packages/integrations && bun run type-check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260416.2",
    "concurrently": "^8.2.2",
    "knip": "^6.4.1",
    "syncpack": "^14.3.0",
    "typescript": "^5"
  },
  "dependencies": {}
}
