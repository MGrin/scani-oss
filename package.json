{
  "name": "scani",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/backend",
    "apps/frontendV2",
    "apps/landing",
    "apps/telegram-bot",
    "packages/*"
  ],
  "scripts": {
    "check-env": "bun run scripts/check-env.ts",
    "dev": "concurrently \"cd apps/backend && bun dev\" \"cd apps/frontendV2 && bun dev\" \"cd apps/landing && bun dev\"",
    "dev:backend": "cd apps/backend && bun dev",
    "dev:frontend": "cd apps/frontendV2 && bun dev",
    "dev:landing": "cd apps/landing && bun dev",
    "dev:mobile:ios": "cd apps/mobile && bun ios",
    "dev:mobile:android": "cd apps/mobile && bun ios",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "cd apps/backend && bun run build",
    "build:frontend": "cd apps/frontendV2 && bun run build",
    "clean": "cd apps/backend && bun clean && cd ../frontendV2 && bun clean",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:backend": "cd apps/backend && bun run lint",
    "lint:frontend": "cd apps/frontendV2 && bun run lint",
    "lint:landing": "cd apps/landing && bun run lint",
    "lint:mobile": "cd apps/mobile && bun run lint",
    "lint:telegram-bot": "cd apps/telegram-bot && bun run lint",
    "lint:shared": "cd packages/shared && bun run lint",
    "lint:scripts": "cd scripts && bun run lint",
    "type-check": "bun run type-check:backend && bun run type-check:frontend && bun run type-check:landing && bun run type-check:telegram-bot && bun run type-check:shared && bun run type-check:scripts",
    "type-check:backend": "cd apps/backend && bun run type-check",
    "type-check:frontend": "cd apps/frontendV2 && bun run type-check",
    "type-check:landing": "cd apps/landing && bun run type-check",
    "type-check:mobile": "cd apps/mobile && bun run type-check",
    "type-check:telegram-bot": "cd apps/telegram-bot && bun run type-check",
    "type-check:shared": "cd packages/shared && bun run type-check",
    "type-check:scripts": "cd scripts && bun run type-check",
    "format": "biome format --write .",
    "check": "biome check .",
    "test": "bun test",
    "test:shared": "cd packages/shared && bun test",
    "test:backend": "cd apps/backend && bun test",
    "test:frontend": "cd apps/frontendV2 && bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:coverage:html": "bun test --coverage --coverage-reporter=html",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/bun": "latest",
    "concurrently": "^8.2.2",
    "typescript": "^5"
  },
  "dependencies": {}
}
