{
  "name": "scani",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"cd apps/backend && bun dev\" \"cd apps/frontend && bun dev\"",
    "dev:backend": "cd apps/backend && bun dev",
    "dev:frontend": "cd apps/frontend && bun dev",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "cd apps/backend && bun build",
    "build:frontend": "cd apps/frontend && bun build",
    "clean": "cd apps/backend && bun clean && cd ../frontend && bun clean",
    "type-check": "cd apps/backend && bun type-check && cd ../frontend && bun type-check",
    "test": "bun test",
    "test:shared": "cd packages/shared && bun test",
    "test:backend": "cd apps/backend && bun test",
    "test:frontend": "cd apps/frontend && bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:coverage:html": "bun test --coverage --coverage-reporter=html",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun apps/backend/src/db/migrate.ts",
    "db:seed": "bun apps/backend/src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:setup": "bun db:migrate && bun db:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bun": "latest",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.31.4",
    "happy-dom": "^15.7.4",
    "msw": "^2.4.9",
    "typescript": "^5"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.5",
    "nanoid": "^5.1.5",
    "postgres": "^3.4.7"
  }
}
