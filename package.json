{
  "name": "scani",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/backend/api",
    "apps/backend/worker",
    "apps/backend/data-provider",
    "apps/frontend/app",
    "apps/frontend/docs",
    "packages/business/*",
    "packages/infra/*",
    "packages/clients/*",
    "packages/frontend/*"
  ],
  "scripts": {
    "prepare": "git config --local core.hooksPath .githooks || true",
    "dev": "concurrently \"cd apps/backend/api && bun dev\" \"cd apps/frontend/app && bun dev\"",
    "dev:docs": "bun --cwd apps/frontend/docs dev",
    "dev:stack": "bun scripts/sync-env.ts && docker compose --profile full up -d --build",
    "dev:stack:down": "docker compose --profile full down",
    "env:sync": "bun scripts/sync-env.ts",
    "build": "bun run --filter='*' build",
    "clean": "bun run --filter='*' clean",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "bun run --filter='*' type-check",
    "test": "bun test --preload ./packages/business/domain/test-preload.ts packages/ apps/ --timeout 30000",
    "coverage": "bun run test --coverage --coverage-reporter=lcov --coverage-dir=coverage && bunx --bun @lcov-viewer/cli@1.3.0 lcov -o coverage/html coverage/lcov.info && bun scripts/coverage-badge.ts",
    "check": "bun run lint && bun run type-check && bun run deps:lint && bun run ci:gen:check",
    "check:fix": "bun run lint:fix && bun run ci:gen",
    "ci:gen": "bun scripts/generate-ci-filters.ts",
    "ci:gen:check": "bun scripts/generate-ci-filters.ts --check",
    "db:migrate": "cd packages/infra/db && bun db:migrate",
    "deps:lint": "syncpack lint",
    "deps:fix": "syncpack fix",
    "deps:unused": "knip --dependencies",
    "deps:outdated": "syncpack update --check",
    "deps:update:minor": "syncpack update --target minor",
    "dockerhub:readmes:check": "bun scripts/sync-dockerhub-readme.ts --check",
    "dockerhub:readmes:sync": "bun scripts/sync-dockerhub-readme.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@lcov-viewer/cli": "^1.3.0",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260416.2",
    "concurrently": "^8.2.2",
    "knip": "^6.4.1",
    "syncpack": "^14.3.0",
    "typescript": "^5"
  },
  "dependencies": {}
}
