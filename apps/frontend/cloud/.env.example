# cloud-frontend Vite SPA env — source of truth for which variables this
# app reads. `scripts/sync-env.ts` copies values from root `.env` into
# `apps/cloud-frontend/.env` for every key listed below. Values prefixed
# with `VITE_` are baked into the bundle at build time — never put
# anything secret here.
#
# In local dev this app runs at http://localhost:5176 and proxies
# `/trpc` + `/api/auth/*` to the data-provider container via
# DATA_PROVIDER_PROXY_TARGET (server-side only, not exposed to the
# browser). Leaving VITE_DATA_PROVIDER_URL unset in dev makes the app
# send relative URLs through the proxy so the Better-Auth session
# cookie stays scoped to `localhost:5176`.
#
# In prod the deploy workflow builds with
# VITE_DATA_PROVIDER_URL=https://data.cloud.scani.xyz so the SPA talks
# to the Fly-hosted data-provider directly; cookies are scoped to the
# `scani.xyz` registrable domain so both `cloud.*` and `data.cloud.*`
# see them as same-site.

# Vite dev-server proxy target (Node-side only; never bundled).
# DATA_PROVIDER_PROXY_TARGET=http://localhost:8082

# Absolute URL of the data-provider public origin. Leave unset in dev
# to hit relative paths through the proxy.
# VITE_DATA_PROVIDER_URL=

# Sentry (optional)
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_RELEASE=
