# Vite SPA build-time env — source of truth for which variables this app
# reads. `scripts/sync-env.ts` copies values from root `.env` into
# `apps/frontendV2/.env` for every key listed below. Values are baked
# into the bundle — never put anything secret here.

VITE_API_URL=http://localhost:3001

# VITE_SENTRY_DSN=
# VITE_SENTRY_ENABLED=false

# PostHog product analytics (optional — unset → analytics no-ops).
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
