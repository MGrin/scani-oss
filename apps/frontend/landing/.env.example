# Landing page Vite SPA env — source of truth for which variables this
# app reads. `scripts/sync-env.ts` copies values from root `.env` into
# `apps/landing/.env` for every key listed below. Values prefixed with
# `VITE_` are baked into the bundle at build time — never put anything
# secret here.
#
# Landing is a pure marketing site; it makes no authenticated calls and
# therefore only needs Sentry wiring. Deploy path is Cloudflare Pages
# via `.github/workflows/deploy-fly.yaml` (deploy-landing job).

# Sentry (optional)
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_RELEASE=

# PostHog product analytics (optional — unset → analytics no-ops).
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
