# Admin app environment variables — source of truth for which variables
# this app reads. `scripts/sync-env.ts` copies values from root `.env`
# into `apps/admin/.env.local` (Next.js dev-priority file) for every key
# listed below.
#
# Local dev: ADMIN_DEV_BYPASS=1 short-circuits the passkey middleware so
# the app is reachable at http://localhost:5175 without registering a
# credential. Never set it in Cloudflare Pages.

NODE_ENV=development

# -----------------------------------------------------------------------------
# Local dev shortcut
# -----------------------------------------------------------------------------
ADMIN_DEV_BYPASS=1

# Backend the admin proxies BullMQ retry/remove to. Dev points at the
# local backend; prod at api.scani.xyz.
BACKEND_BASE_URL=http://localhost:3001

# Shared HMAC secret with the backend (must equal ADMIN_JOBS_HMAC_SECRET
# on the backend side).
ADMIN_JOBS_HMAC_SECRET=dev_admin_hmac_change_me_not_prod_safe

# -----------------------------------------------------------------------------
# Passkey auth — required when ADMIN_DEV_BYPASS is not "1" (and always in prod)
# -----------------------------------------------------------------------------
# Generate with: cd apps/admin && bun run register-passkey
# ADMIN_RP_ID=localhost
# ADMIN_ORIGIN=http://localhost:5175
# ADMIN_PASSKEY_CREDENTIAL_ID=
# ADMIN_PASSKEY_PUBLIC_KEY=
# ADMIN_SESSION_SECRET=
# ADMIN_BOOTSTRAP_TOKEN=

# -----------------------------------------------------------------------------
# Provider API credentials (read-only queries against vendor dashboards)
# -----------------------------------------------------------------------------
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# UPSTASH_EMAIL=
# UPSTASH_API_KEY=

# -----------------------------------------------------------------------------
# Sentry — optional
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
