# Local dev: skip passkey auth by setting this. Never set it in Cloudflare Pages.
ADMIN_DEV_BYPASS=1

# Required once you disable ADMIN_DEV_BYPASS (and always in production):
# ADMIN_RP_ID=localhost
# ADMIN_ORIGIN=http://localhost:5175
# ADMIN_PASSKEY_CREDENTIAL_ID=
# ADMIN_PASSKEY_PUBLIC_KEY=
# ADMIN_SESSION_SECRET=
#
# To generate the three passkey values, run:
#   cd apps/admin && bun run register-passkey
#
# For production, register against rpID=admin.scani.xyz and copy into
# Cloudflare Pages secrets via `wrangler pages secret put`.
