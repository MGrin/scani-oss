{
  "name": "@scani/backend",
  "private": true,
  "type": "module",
  "exports": {
    "./types": "./src/types.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --target=bun --minify --outfile=dist/server",
    "start": "./dist/server",
    "clean": "rm -rf dist",
