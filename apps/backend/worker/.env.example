# Worker environment variables — source of truth for which variables this
# app reads. `scripts/sync-env.ts` treats every key listed below as an
# allowlist: it copies values from root `.env` into `apps/worker/.env`.
#
# ENCRYPTION_KEY must match the backend's byte-for-byte, otherwise stored
# integration credentials can't be decrypted at job time.

NODE_ENV=development

DATABASE_URL=postgres://scani:scani@localhost:5433/scani?sslmode=disable
REDIS_URL=redis://localhost:6380

ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
WORKER_CONCURRENCY=4

# Route every outbound 3rd-party call (pricing, chains, AI, email, R2, OG)
# through the data-provider. See the root .env.example for the tier matrix.
SCANI_CLOUD_URL=http://localhost:8082
SCANI_CLOUD_API_KEY=dev_data_provider_key_change_me_not_prod_safe

# Optional local-fallback keys. Ignored when SCANI_CLOUD_URL is set.
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o
# COINGECKO_API_KEY=
# FINNHUB_API_KEY=
# ETHERSCAN_API_KEY=
# HELIUS_API_KEY=
# GOOGLE_SHEETS_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY=
# BINANCE_OAUTH_CLIENT_ID=
# BINANCE_OAUTH_CLIENT_SECRET=

# Object storage (MinIO in dev, any S3-compatible store in prod).
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=job-uploads-dev

# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
