{
  "name": "@scani/backend",
  "private": true,
  "type": "module",
  "exports": {
    "./types": "./src/types.ts",
    "./router": "./src/router.ts",
    "./services": "./src/application/services/index.ts",
    "./use-cases": "./src/application/use-cases/index.ts",
    "./repositories": "./src/infrastructure/repositories/index.ts"
  },
  "scripts": {
    "dev": "LOG_LEVEL=debug LOG_PRETTY=true bun run --watch src/index.ts",
    "dev:verbose": "LOG_LEVEL=trace LOG_PRETTY=true LOG_SQL_QUERIES=true LOG_WEBSOCKET_MESSAGES=true bun run --watch src/index.ts",
    "dev:quiet": "LOG_LEVEL=warn LOG_PRETTY=true bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "start:prod": "NODE_ENV=production LOG_LEVEL=info LOG_PRETTY=false bun run dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:coverage:html": "bun test --coverage --coverage-reporter=html",
    "db:generate": "bun drizzle-kit generate",
    "db:drop": "bun drizzle-kit drop",
    "db:migrate": "bun drizzle-kit migrate",
    "db:setup": "bun run db:migrate",
    "db:studio": "bun drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.3",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/trpc": "^1.1.0",
    "@scani/shared": "workspace:*",
    "@sentry/bun": "^10.21.0",
    "@supabase/supabase-js": "^2.57.4",
    "@trpc/server": "^10.45.2",
    "@types/jsonwebtoken": "^9.0.10",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.44.5",
    "elysia": "^1.3.21",
    "ethers": "^6.15.0",
    "googleapis": "^160.0.0",
    "jsonwebtoken": "^9.0.2",
    "open-graph-scraper": "^6.10.0",
    "pino": "^9.9.4",
    "postgres": "^3.4.4",
    "reflect-metadata": "^0.2.2",
    "typedi": "^0.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4",
    "typescript": "^5"
  }
}
