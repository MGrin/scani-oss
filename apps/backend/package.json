  "exports": {
    "./src/types": "./src/types.ts",
    "./src/router": "./src/router.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun --sourcemap=linked",
