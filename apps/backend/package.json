{
  "name": "@scani/backend",
  "private": true,
  "type": "module",
  "exports": {
    "./types": "./src/types.ts"
  },
  "scripts": {
    "dev": "LOG_LEVEL=debug LOG_PRETTY=true bun run --watch src/index.ts",
    "dev:verbose": "LOG_LEVEL=trace LOG_PRETTY=true LOG_SQL_QUERIES=true LOG_WEBSOCKET_MESSAGES=true bun run --watch src/index.ts",
    "dev:quiet": "LOG_LEVEL=warn LOG_PRETTY=true bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "start:prod": "NODE_ENV=production LOG_LEVEL=info LOG_PRETTY=false bun run dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:coverage:html": "bun test --coverage --coverage-reporter=html"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.3",
    "@elysiajs/trpc": "^1.1.0",
    "@scani/shared": "workspace:*",
    "@trpc/server": "^10.45.2",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.44.5",
    "elysia": "^1.3.21",
    "pino": "^9.9.4",
    "pino-pretty": "^13.1.1",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/decimal.js": "^7.4.3",
    "@types/pino": "^7.0.5",
    "@types/ws": "^8.5.10",
    "typescript": "^5"
  }
}
