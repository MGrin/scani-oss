{
  "name": "@scani/backend",
  "private": true,
  "type": "module",
  "exports": {
    "./types": "./src/types.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun --sourcemap=linked",
    "start": "bun run dist/index.js",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/trpc": "^1.1.0",
    "@scani/core": "workspace:*",
    "@scani/integrations": "workspace:*",
    "@scani/shared": "workspace:*",
    "@trpc/server": "^10.45.4",
    "better-auth": "^1.6.5",
    "bullmq": "^5.74.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "ioredis": "^5.10.1",
    "nodemailer": "^6",
    "open-graph-scraper": "^6.11.0",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "typedi": "^0.10.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/nodemailer": "^6",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
