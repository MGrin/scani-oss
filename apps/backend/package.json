    "@scani/shared": "workspace:*",
    "@trpc/server": "^10.45.2",
    "better-auth": "^1.2.7",
    "bullmq": "^5.21.0",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.44.5",
    "elysia": "^1.3.21",
    "ioredis": "^5.4.1",
    "ethers": "^6.15.0",
    "googleapis": "^160.0.0",
    "jose": "^5.9.6",
    "nodemailer": "^6.9.15",
    "open-graph-scraper": "^6.10.0",
    "pino": "^9.9.4",
