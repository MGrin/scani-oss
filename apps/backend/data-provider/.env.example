# data-provider environment variables — source of truth for which variables
# this app reads. `scripts/sync-env.ts` uses every key listed below (active or
# commented) as an allowlist: for each key it finds, it copies the value from
# the root `.env` into `apps/data-provider/.env`.
#
# The data-provider is the only service that holds provider API keys (AI,
# pricing, blockchain, email, storage) — backend + worker call it over tRPC
# with the `SCANI_CLOUD_API_KEY` bearer. In local dev the compose file sets
# CLOUD_MANAGEMENT_ENABLED=true so this service also runs the Tier 2 cloud-
# frontend stack (Better-Auth + cloud_usage_events + cloud_api_keys).

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=8082
HOST=localhost

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6380
DATABASE_URL=postgres://scani:scani@localhost:5433/scani?sslmode=disable

# -----------------------------------------------------------------------------
# Inbound auth — shared bearer token backend + worker present to reach us.
# In OSS / single-tenant mode this is the only accepted key; in Tier 2/3
# it remains a superuser fallback alongside DB-backed `cloud_api_keys`.
# -----------------------------------------------------------------------------
DATA_PROVIDER_API_KEY=dev_data_provider_key_change_me_not_prod_safe

# -----------------------------------------------------------------------------
# Cloud management (Tier 2/3) — when true, enables DB-backed API keys,
# Better-Auth cookie sessions for the management console, and Postgres-backed
# per-request metering (`cloud_usage_events`). Env block below is required
# together in production.
# -----------------------------------------------------------------------------
CLOUD_MANAGEMENT_ENABLED=true
BETTER_AUTH_SECRET=dev_cloud_better_auth_secret_change_me_not_prod_safe
BETTER_AUTH_URL=http://localhost:8082
CLOUD_FRONTEND_ORIGIN=http://localhost:5176

# -----------------------------------------------------------------------------
# Email — Fastmail JMAP sends Better-Auth magic links / OTPs.
# Unset in dev → magic links log to stdout. Required in prod.
# SMTP_URL is the dev fallback for sendgrid-style relays (ignored when
# FASTMAIL_API_TOKEN is set).
# -----------------------------------------------------------------------------
SMTP_URL=smtp://localhost:1026
SMTP_FROM=no-reply@scani.local
# FASTMAIL_API_TOKEN=

# -----------------------------------------------------------------------------
# Object storage (MinIO in dev, any S3-compatible store in prod)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=job-uploads-dev

# -----------------------------------------------------------------------------
# Provider credentials — every outbound 3rd-party call terminates here.
# All optional at the schema level; the router for a missing provider
# throws at call-time with a clear message.
# -----------------------------------------------------------------------------

# AI — screenshot parsing + chat extractions.
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o
# AI_DEFAULT_PROVIDER=openai

# Pricing — FX + crypto spot quotes.
# COINGECKO_API_KEY=
# FINNHUB_API_KEY=
# Google Sheets manual-asset prices: base64-encoded JSON service-account key.
# GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_SHEETS_ID=

# Blockchain — public EVM + Solana read-only RPCs.
# ETHERSCAN_API_KEY=
# HELIUS_API_KEY=

# -----------------------------------------------------------------------------
# Sentry — error tracking (optional; init gates on DSN presence)
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=
