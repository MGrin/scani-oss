# Backend Environment Variables
# Copy this file to .env.local and customize as needed

# Server Configuration
PORT=3001
HOST=localhost
NODE_ENV=development

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Database Configuration
# PostgreSQL connection string (required for all environments)
# For local development, you can use your Supabase PostgreSQL URL or a local PostgreSQL instance
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# Database Connection Pool Configuration (optional - defaults shown)
# Maximum number of connections in the pool (default: 20)
DB_MAX_CONNECTIONS=20
# Idle connection timeout in seconds (default: 30)
DB_IDLE_TIMEOUT=30
# Connection timeout in seconds (default: 10)
DB_CONNECT_TIMEOUT=10
# Maximum connection lifetime in seconds (default: 1800 / 30 minutes)
DB_MAX_LIFETIME=1800

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Sentry Configuration (optional - for error tracking)
# Get your DSN from https://sentry.io/settings/projects/YOUR_PROJECT/keys/
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# Enable Sentry in development (optional)
SENTRY_ENABLED=false

# Logging Configuration
LOG_LEVEL=debug
# Options: trace, debug, info, warn, error, fatal

# Enable/disable specific log features
LOG_SQL_QUERIES=true
LOG_REQUEST_BODIES=false
LOG_RESPONSE_BODIES=false
LOG_WEBSOCKET_MESSAGES=true

# Log formatting
LOG_PRETTY=true
LOG_TIMESTAMP=true
LOG_COLORIZE=true

FINNHUB_API_KEY=
COINGECKO_API_KEY=OPTIONAL

# Etherscan API Keys (for ERC-20 token discovery)
# Get free keys at: https://etherscan.io/apis
# Note: You can use the same key for all Etherscan-family APIs
ETHERSCAN_API_KEY=your_etherscan_api_key_here
# Optional: Chain-specific keys (if you have separate keys)
POLYGONSCAN_API_KEY=
BSCSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
SNOWTRACE_API_KEY=

# Google Sheets Fallback Pricing (Optional - Live Prices Only)
# Google Sheets ID for fallback pricing using GOOGLEFINANCE function
GOOGLE_SHEETS_ID=your_google_sheets_id_here
# Google Service Account Key as base64-encoded JSON (encode the entire JSON object)
# Example: echo '{"type":"service_account","project_id":"your-project",...}' | base64
GOOGLE_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_json_here

OPENAI_API_KEY=
OPENAI_VISION_MODEL=
# Note: OPENAI_API_KEY is required for both screenshot parsing and Telegram bot AI agent

PERPLEXITY_API_KEY=
PERPLEXITY_VISION_MODEL=

DEEPSEEK_API_KEY=
DEEPSEEK_VISION_MODEL=

# Telegram Bot Configuration (optional - for AI chatbot integration)
# Get your bot token from @BotFather on Telegram: https://t.me/botfather
# Requires OPENAI_API_KEY to be set for AI agent functionality
# See docs/features/TELEGRAM_BOT.md for setup instructions
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here