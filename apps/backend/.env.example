# Backend environment variables — the source of truth for which variables
# this app reads. `scripts/sync-env.ts` uses every key listed below (active
# or commented) as an allowlist: for each key it finds, it copies the value
# from the root `.env` into `apps/backend/.env`.
#
# To add a new variable: drop it into this file (commented is fine if
# optional) and re-run `bun run env:sync`.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
HOST=localhost

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://scani:scani@localhost:5433/scani?sslmode=disable
REDIS_URL=redis://localhost:6380

# -----------------------------------------------------------------------------
# Public URLs + auth
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
BETTER_AUTH_SECRET=dev_secret_change_me_this_is_not_production_safe
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
ADMIN_JOBS_HMAC_SECRET=dev_admin_hmac_change_me_not_prod_safe
# COOKIE_DOMAIN=.scani.xyz   # production only

# -----------------------------------------------------------------------------
# Email — Mailpit in dev, Fastmail JMAP in prod
# -----------------------------------------------------------------------------
SMTP_URL=smtp://localhost:1026
SMTP_FROM=no-reply@scani.local
# FASTMAIL_API_TOKEN=

# -----------------------------------------------------------------------------
# Data-provider — where outbound 3rd-party calls terminate
# -----------------------------------------------------------------------------
# See the root .env.example for the tier matrix.
SCANI_CLOUD_URL=http://localhost:8082
SCANI_CLOUD_API_KEY=dev_data_provider_key_change_me_not_prod_safe

# -----------------------------------------------------------------------------
# External APIs — local fallback keys (ignored when SCANI_CLOUD_URL is set)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o
# PERPLEXITY_API_KEY=
# PERPLEXITY_VISION_MODEL=
# DEEPSEEK_API_KEY=
# DEEPSEEK_VISION_MODEL=
# COINGECKO_API_KEY=
# FINNHUB_API_KEY=
# ETHERSCAN_API_KEY=
# HELIUS_API_KEY=
# GOOGLE_SHEETS_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY=
# BINANCE_OAUTH_CLIENT_ID=
# BINANCE_OAUTH_CLIENT_SECRET=
# BINANCE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/binance/callback

# -----------------------------------------------------------------------------
# Object storage (MinIO in dev, Cloudflare R2 in prod)
# -----------------------------------------------------------------------------
R2_ENDPOINT=http://localhost:9000
R2_PUBLIC_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=scani-job-uploads-dev
# R2_ACCOUNT_ID=   # prod only — derives endpoint when R2_ENDPOINT unset

# -----------------------------------------------------------------------------
# Logging + Sentry
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_SQL_QUERIES=false
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
