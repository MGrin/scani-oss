{
  "name": "@scani/telegram-bot",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Telegram bot for Scani Finance with AI agent",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.12",
    "@scani/backend": "workspace:*",
    "@scani/shared": "workspace:*",
    "ai": "^4.0.28",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "decimal.js": "^10.6.0",
    "openai": "^4.77.3",
    "telegraf": "^4.16.3",
    "typedi": "^0.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
