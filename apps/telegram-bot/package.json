{
  "name": "@scani/telegram-bot",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Telegram bot for Scani Finance with AI agent",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@scani/shared": "workspace:*",
    "ai": "^4.0.28",
    "openai": "^4.77.3",
    "telegraf": "^4.16.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
