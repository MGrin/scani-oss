# Cron environment variables — source of truth for which variables this
# app reads. `scripts/sync-env.ts` copies values from root `.env` into
# `apps/cron/.env` for every key listed below.
#
# Cron is consumed as a library by the worker deploy — it does not have
# its own Fly app. The entries here exist so local `bun run dev` against
# `apps/cron` works against the same root `.env` as every other app,
# and so provider keys needed by the cron jobs (pricing, wallet/exchange
# balances, APY payouts) are surfaced in one place.

NODE_ENV=development

DATABASE_URL=postgres://scani:scani@localhost:5433/scani?sslmode=disable

# Credential encryption key — must match backend/worker byte-for-byte
# so stored integration credentials can be decrypted at job-run time.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Legacy Supabase wiring — retained until the cron runner is fully
# migrated to Better-Auth (tracked separately). All three are read by
# `apps/cron/src/config/env.ts`.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional integration keys — cron jobs call external APIs directly
# when run locally. In prod these move into the data-provider.
# OPENAI_API_KEY=
# COINGECKO_API_KEY=
# FINNHUB_API_KEY=
