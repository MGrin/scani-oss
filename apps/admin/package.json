    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "tsgo --noEmit",
    "register-passkey": "bun scripts/register-passkey.ts",
    "sync-env": "./scripts/sync-env.sh"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
