# Admin Environment Variables
# Cloudflare Pages deployment reads these via `vars` in wrangler.toml plus
# secrets. For local `next dev`, copy to .env.local and fill in.

# Passkey-gated admin session
ADMIN_SESSION_SECRET=
ADMIN_BOOTSTRAP_TOKEN=
ADMIN_PASSKEY_CREDENTIAL_ID=
ADMIN_PASSKEY_PUBLIC_KEY=

# Dev-only: bypasses the passkey middleware when set to "1"
ADMIN_DEV_BYPASS=

# Cloudflare API credentials (used to query account resources)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Upstash Redis credentials (used to query BullMQ queue state)
UPSTASH_EMAIL=
UPSTASH_API_KEY=

# Backend base URL — admin proxies BullMQ retry/remove requests here.
BACKEND_BASE_URL=https://api.scani.xyz

# Shared HMAC secret with the backend (must match ADMIN_JOBS_HMAC_SECRET
# in the backend's env). Used to sign retry/remove requests.
ADMIN_JOBS_HMAC_SECRET=
