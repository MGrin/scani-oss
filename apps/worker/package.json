{
  "name": "@scani/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun --sourcemap=linked",
    "start": "bun run dist/index.js",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@scani/core": "workspace:*",
    "@scani/cron": "workspace:*",
    "@scani/integrations": "workspace:*",
    "@scani/shared": "workspace:*",
    "bullmq": "^5.74.1",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "pino": "^9.14.0",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "typedi": "^0.10.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
