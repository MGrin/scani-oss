# Worker Environment Variables
# Copy to .env.local for local dev. The worker runs the BullMQ job loop
# against the same Redis + Postgres as the backend.

NODE_ENV=development

# Database — same DSN as the backend (shared source of truth).
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# Redis (BullMQ queue + pub/sub). Use rediss:// for TLS.
REDIS_URL=redis://localhost:6379

# Encryption key used to decrypt integration credentials stored by the
# backend. Must match the backend's ENCRYPTION_KEY exactly.
ENCRYPTION_KEY=

# How many jobs to run in parallel on this worker. Default 4.
WORKER_CONCURRENCY=4

# Cloudflare R2 — must match the backend's settings so the worker can
# read screenshot and file-import blobs the user uploaded.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=scani-job-uploads

# External API configuration — same as backend.
EXTERNAL_API_MODE=direct
COINGECKO_API_KEY=
FINNHUB_API_KEY=
