# Worker environment variables — source of truth for which variables this
# app reads. `scripts/sync-env.ts` treats every key listed below as an
# allowlist: it copies values from root `.env` into `apps/worker/.env`.
#
# ENCRYPTION_KEY must match the backend's byte-for-byte, otherwise stored
# integration credentials can't be decrypted at job time.

NODE_ENV=development

DATABASE_URL=postgres://scani:scani@localhost:5433/scani?sslmode=disable
REDIS_URL=redis://localhost:6380

ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
WORKER_CONCURRENCY=4

EXTERNAL_API_MODE=direct
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o
# PERPLEXITY_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_VISION_MODEL=
# COINGECKO_API_KEY=
# FINNHUB_API_KEY=
# ETHERSCAN_API_KEY=
# HELIUS_API_KEY=
# GOOGLE_SHEETS_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY=

# Object storage (MinIO in dev, R2 in prod).
R2_ENDPOINT=http://localhost:9000
R2_PUBLIC_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=scani-job-uploads-dev
# R2_ACCOUNT_ID=

# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
