{
  "name": "@scani/db",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Drizzle schema + postgres.js connection + migrations + BaseRepository. The database infrastructure layer — consumed by @scani/domain repositories and cron/worker jobs.",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./connection": "./src/connection.ts",
    "./transaction": "./src/transaction.ts",
    "./base-repository": "./src/base-repository.ts",
    "./migrate": "./src/migrate.ts"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "tsgo --noEmit",
    "db:generate": "bun drizzle-kit generate",
    "db:drop": "bun drizzle-kit drop",
    "db:migrate": "bun src/migrate.ts",
    "db:studio": "bun drizzle-kit studio"
  },
  "dependencies": {
    "@scani/logging": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "typedi": "^0.10.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
}
