{
  "name": "@scani/frontend-shared",
  "private": true,
  "version": "0.0.0",
  "description": "Shared React primitives for apps/frontendV2 (main app) and apps/cloud-frontend (Tier 2 key/usage UI). Ships the Tailwind preset + CSS variables, shadcn UI components, ThemeContext, ErrorBoundary, UpdateBanner, PWA helpers, and auth/tRPC client factories — everything that wants to look and behave identically across both SPAs.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
