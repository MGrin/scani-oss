    "./cloud-services/cloud-email-service": "./src/cloud-services/cloud-email-service.ts",
    "./cloud-services/cloud-storage": "./src/cloud-services/cloud-storage.ts",
    "./cloud-services/cloud-og-client": "./src/cloud-services/cloud-og-client.ts",
