{
  "name": "@scani/core",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Core business logic, database, and services for Scani Finance",
  "exports": {
    ".": "./src/index.ts",
    "./config/*": "./src/config/*.ts",
    "./database": "./src/database/index.ts",
    "./database/schema": "./src/database/schema.ts",
    "./database/connection": "./src/database/connection.ts",
    "./repositories": "./src/repositories/index.ts",
    "./repositories/*": "./src/repositories/*.ts",
    "./services": "./src/services/index.ts",
    "./services/*": "./src/services/*.ts",
    "./use-cases": "./src/use-cases/index.ts",
    "./use-cases/*": "./src/use-cases/*.ts",
    "./entities": "./src/entities/index.ts",
    "./features": "./src/features/index.ts",
    "./features/implementations": "./src/features/implementations.ts",
    "./external-services/ai": "./src/external-services/ai/index.ts",
    "./external-services/blockchain": "./src/external-services/blockchain/index.ts",
    "./external-services/pricing": "./src/external-services/pricing/index.ts",
    "./external-services/file-import": "./src/external-services/file-import/index.ts",
    "./queues": "./src/queues/index.ts",
    "./utils/logger": "./src/utils/logger.ts",
    "./utils/request-cache": "./src/utils/request-cache.ts",
    "./utils/performance-monitor": "./src/utils/performance-monitor.ts",
    "./utils/retry": "./src/utils/retry.ts",
    "./utils/circuit-breaker": "./src/utils/circuit-breaker.ts",
    "./utils/encryption": "./src/utils/encryption.ts"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "tsgo --noEmit",
    "db:generate": "bun drizzle-kit generate",
    "db:drop": "bun drizzle-kit drop",
    "db:migrate": "bun src/database/migrate.ts",
    "db:studio": "bun drizzle-kit studio"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@scani/integrations": "workspace:*",
    "@scani/rate-limiter": "workspace:*",
    "@scani/shared": "workspace:*",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^160.0.0",
    "ofx-js": "^0.2.0",
    "papaparse": "^5.5.3",
    "pino": "^9.14.0",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "typedi": "^0.10.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
}
