{
  "name": "@scani/domain",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Domain layer: services, repositories, use cases, features. Sits on top of @scani/db + the adapter packages (@scani/queue, @scani/integrations, @scani/ai-providers, @scani/pricing-providers, @scani/storage, @scani/email, @scani/realtime).",
  "exports": {
    ".": "./src/index.ts",
    "./config/*": "./src/config/*.ts",
    "./repositories": "./src/repositories/index.ts",
    "./repositories/*": "./src/repositories/*.ts",
    "./services": "./src/services/index.ts",
    "./services/*": "./src/services/*.ts",
    "./use-cases": "./src/use-cases/index.ts",
    "./use-cases/*": "./src/use-cases/*.ts",
    "./features": "./src/features/index.ts",
    "./external-services/file-import": "./src/external-services/file-import/index.ts"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@scani/ai-providers": "workspace:*",
    "@scani/cloud-client": "workspace:*",
    "@scani/db": "workspace:*",
    "@scani/integrations": "workspace:*",
    "@scani/logging": "workspace:*",
    "@scani/pricing-providers": "workspace:*",
    "@scani/shared": "workspace:*",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "ofx-js": "^0.2.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "postgres": "^3.4.9",
    "typedi": "^0.10.0"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "typescript": "^5"
  }
}
