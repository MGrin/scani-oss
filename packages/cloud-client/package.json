{
  "name": "@scani/cloud-client",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Typed tRPC client + domain-facing adapters for apps/data-provider; consumed by backend and worker.",
  "exports": {
    ".": "./src/index.ts",
    "./adapters/pricing": "./src/adapters/pricing.ts",
    "./adapters/ai": "./src/adapters/ai.ts",
    "./adapters/chains": "./src/adapters/chains.ts",
    "./adapters/email": "./src/adapters/email.ts",
    "./adapters/storage": "./src/adapters/storage.ts",
    "./adapters/og": "./src/adapters/og.ts",
    "./storage-facade": "./src/storage-facade.ts",
    "./health-probe": "./src/health-probe.ts",
    "./runtime": "./src/runtime.ts"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@scani/ai-providers": "workspace:*",
    "@scani/data-provider": "workspace:*",
    "@scani/integrations": "workspace:*",
    "@scani/logging": "workspace:*",
    "@scani/pricing-providers": "workspace:*",
    "@scani/storage": "workspace:*",
    "@trpc/client": "^10.45.4"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
