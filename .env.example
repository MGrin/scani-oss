# Scani environment variables — single source of truth for local dev.
#
# Quick start:
#   cp .env.example .env
#   bun run dev:stack
#   open http://localhost:5173
#
# `bun run dev:stack` runs scripts/sync-env.ts (which generates per-app
# .env files from this root file) then boots the full docker compose stack.
# With the defaults below the stack is completely self-contained — no
# Cloudflare, Fly, Neon, Upstash, or Fastmail credentials are needed.
# Values marked "API key" unlock external features (screenshot parsing,
# EVM wallet sync, premium pricing); auth, holdings, FX pricing, and
# screenshot storage (via local MinIO) all work without any API key.
#
# The same variable set powers three deployment tiers:
#   Tier 1 — fully self-hosted OSS:  bun run dev:stack
#   Tier 2 — self-hosted + Scani Cloud proxy:  EXTERNAL_API_MODE=scani-cloud
#   Tier 3 — managed SaaS:  Fly + Neon + Upstash + Cloudflare R2 + Pages
# =============================================================================

# -----------------------------------------------------------------------------
# CORE — required for backend + worker to boot
# -----------------------------------------------------------------------------
NODE_ENV=development

# Postgres + Redis — host-side ports from docker-compose.yml infra services.
# For docker compose --profile full, the service-to-service URLs are set
# inside the compose file itself; these defaults are for `bun dev` on host.
DATABASE_URL=postgres://scani:scani@localhost:5433/scani?sslmode=disable
REDIS_URL=redis://localhost:6380

# Postgres connection-pool size. Defaults to 20, which matches a direct
# endpoint (Neon direct, Fly Postgres, Render). On Neon's managed pooler
# (`*-pooler.neon.tech` or `?pgbouncer=true`) the per-app budget is far
# smaller — set this to 5 or so to avoid exhausting the pooler. The
# backend prints a loud warning at boot when it detects a pooled URL
# with the default pool size.
# POSTGRES_POOL_MAX=20

# Backend HTTP server (used by `bun dev:backend` — docker uses 8080 inside
# the container and maps it to :3001 on the host).
PORT=3001
HOST=localhost

# Public URLs. Must match what the browser actually sees. FRONTEND_URL is
# used for CORS + Better-Auth cookie scope; BACKEND_URL is embedded in
# magic-link emails.
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# Better-Auth session signing. 32+ chars. Generate with `openssl rand -hex 32`.
# Rotating this invalidates every active session.
BETTER_AUTH_SECRET=dev_secret_change_me_this_is_not_production_safe

# AES-256-GCM key that encrypts integration credentials at rest. 32 hex chars.
# MUST match the worker's ENCRYPTION_KEY byte-for-byte — otherwise the worker
# cannot decrypt what the backend wrote, and every import silently fails.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# HMAC secret for admin → backend requests (BullMQ retry/remove, DLQ replay).
# MUST match the admin app's ADMIN_JOBS_HMAC_SECRET.
ADMIN_JOBS_HMAC_SECRET=dev_admin_hmac_change_me_not_prod_safe

# -----------------------------------------------------------------------------
# EMAIL — magic-link delivery
# -----------------------------------------------------------------------------
# Local dev uses Mailpit (docker-compose service). Open http://localhost:8026
# to view emails the backend sends. Production uses Fastmail JMAP via
# FASTMAIL_API_TOKEN.
SMTP_URL=smtp://localhost:1026
SMTP_FROM=no-reply@scani.local
# FASTMAIL_API_TOKEN=fmu1-...   # takes precedence over SMTP_URL when set

# -----------------------------------------------------------------------------
# OBJECT STORAGE — S3-compatible (MinIO locally, Cloudflare R2 in prod)
# -----------------------------------------------------------------------------
# In local dev the compose stack runs a MinIO container with the creds below.
# R2_ENDPOINT is the server-side URL (what backend/worker talk to); docker
# compose overrides this with http://minio:9000 inside the container network.
# R2_PUBLIC_ENDPOINT is baked into presigned URLs, so the browser can reach
# the bucket — for local dev that's http://localhost:9000.
#
# For production R2: unset R2_ENDPOINT / R2_PUBLIC_ENDPOINT and set
# R2_ACCOUNT_ID — the client derives the standard Cloudflare URL.
R2_ENDPOINT=http://localhost:9000
R2_PUBLIC_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=scani-job-uploads-dev
# R2_ACCOUNT_ID=                # prod only — derives endpoint if R2_ENDPOINT unset

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_SQL_QUERIES=false

# -----------------------------------------------------------------------------
# FRONTEND (Vite — values are baked into the SPA bundle at build time)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3001
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENABLED=false

# -----------------------------------------------------------------------------
# ADMIN APP (apps/admin — Next.js, passkey-gated in prod)
# -----------------------------------------------------------------------------
ADMIN_DEV_BYPASS=1
BACKEND_BASE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# EXTERNAL API MODE
# -----------------------------------------------------------------------------
# direct      — hit CoinGecko / Finnhub / Etherscan with your own keys below
# scani-cloud — proxy via cloud.scani.xyz (Tier 2; not yet live)
EXTERNAL_API_MODE=direct
# SCANI_CLOUD_API_URL=https://cloud.scani.xyz
# SCANI_CLOUD_CLIENT_TOKEN=

# -----------------------------------------------------------------------------
# PROVIDER API KEYS — optional; only needed for specific features
# -----------------------------------------------------------------------------
# Fiat/FX pricing uses exchangerate-api.com (no key). Crypto pricing without
# a CoinGecko key falls back to the public tier (rate-limited).
# COINGECKO_API_KEY=
# FINNHUB_API_KEY=

# OpenAI (screenshot parsing). Without a key, screenshot import is disabled.
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o
# PERPLEXITY_API_KEY=
# DEEPSEEK_API_KEY=

# Blockchain explorers — EVM + Solana wallet-balance sync.
# Etherscan's single V2 key covers all EVM chains (Polygon, Arbitrum, …).
# ETHERSCAN_API_KEY=
# HELIUS_API_KEY=

# Binance OAuth — exchange connection flow.
# BINANCE_OAUTH_CLIENT_ID=
# BINANCE_OAUTH_CLIENT_SECRET=
# BINANCE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/binance/callback

# -----------------------------------------------------------------------------
# CROSS-SUBDOMAIN COOKIES (production only)
# -----------------------------------------------------------------------------
# Set to ".<your-domain>" so the session cookie minted on api.<domain>
# reaches app.<domain>. Leave unset in dev.
# COOKIE_DOMAIN=.scani.xyz

# -----------------------------------------------------------------------------
# SENTRY (optional — error tracking)
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
