# Scani environment variables.
#
# Copy to `.env` for local dev. Production deployments set these via Fly
# secrets / Cloudflare Pages env vars (see .github/workflows/deploy-fly.yaml
# and infra/terraform/*).
#
# The same variable set powers three deployment tiers:
#   - Tier 1 — fully self-hosted OSS: docker compose --profile full up.
#   - Tier 2 — self-hosted with Scani Cloud proxy for paid API calls:
#     set EXTERNAL_API_MODE=scani-cloud.
#   - Tier 3 — managed SaaS: Fly + Neon + Upstash + Cloudflare Pages.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://scani:scani@localhost:5433/scani?sslmode=disable
REDIS_URL=redis://localhost:6380
NODE_ENV=development

# Frontend origin — used for CORS + Better-Auth cookie scope.
FRONTEND_URL=http://localhost:5173
# This backend's own public URL — Better-Auth uses it to generate magic-link
# callback URLs.
BACKEND_URL=http://localhost:3001

# Better-Auth session-signing secret. 32+ chars. Generate with `openssl rand -hex 32`.
BETTER_AUTH_SECRET=dev_secret_change_me_this_is_not_production_safe

# AES-256-GCM key that encrypts integration credentials at rest. 32+ chars.
# Required in production. Generate with `openssl rand -hex 32`.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# -----------------------------------------------------------------------------
# EMAIL — either SMTP or Fastmail JMAP
# -----------------------------------------------------------------------------
# Use SMTP_URL for self-hosting with any SMTP provider. Scani's managed
# deployment uses FASTMAIL_API_TOKEN instead (avoids the need for a separate
# app-specific password).
#
# Local dev: smtp://localhost:1026 (Mailpit, no auth; UI at http://localhost:8026)
# Fastmail via SMTP (app password): smtps://user%40fastmail.com:app-pass@smtp.fastmail.com:465
SMTP_URL=smtp://localhost:1026
SMTP_FROM=no-reply@scani.local
# FASTMAIL_API_TOKEN=fmu1-...   # takes precedence over SMTP_URL when set

# -----------------------------------------------------------------------------
# SCANI CROSS-SUBDOMAIN COOKIES (production only)
# -----------------------------------------------------------------------------
# Set to ".<your-domain>" in production so the session cookie minted on
# api.<domain> reaches app.<domain>. Leave unset in dev (localhost cookies
# work without an explicit domain).
# COOKIE_DOMAIN=.scani.xyz

# -----------------------------------------------------------------------------
# EXTERNAL API MODE
# -----------------------------------------------------------------------------
# `direct`      — hit CoinGecko/Finnhub/Etherscan directly with your own keys.
# `scani-cloud` — proxy via cloud.scani.xyz (Tier 2; not yet live).
EXTERNAL_API_MODE=direct
# SCANI_CLOUD_API_URL=https://cloud.scani.xyz
# SCANI_CLOUD_CLIENT_TOKEN=

# -----------------------------------------------------------------------------
# PROVIDER API KEYS — optional, only used when EXTERNAL_API_MODE=direct
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# COINGECKO_API_KEY=
# FINNHUB_API_KEY=
# Blockchain explorers — needed for EVM + Solana wallet-balance sync.
# Etherscan's single key works across all EVM chains (Polygon, Arbitrum, etc.).
# Helius is the recommended Solana RPC; the public mainnet-beta endpoint
# rate-limits too aggressively for the hourly cron.
# ETHERSCAN_API_KEY=
# HELIUS_API_KEY=
# BINANCE_OAUTH_CLIENT_ID=
# BINANCE_OAUTH_CLIENT_SECRET=
# BINANCE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/binance/callback

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
PORT=3001
HOST=localhost

# -----------------------------------------------------------------------------
# FRONTEND (Vite build-time — values are baked into the static bundle)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3001
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENABLED=false

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_SQL_QUERIES=false
LOG_PRETTY=true
