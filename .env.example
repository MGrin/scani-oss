# Scani Personal Finance Management - Environment Variables
# 
# This is an example file showing all environment variables used in the application.
# Copy the relevant variables to your local .env files:
# - apps/backend/.env.local (for backend variables)
# - apps/frontend/.env.local (for frontend variables)

# =============================================================================
# BACKEND ENVIRONMENT VARIABLES (apps/backend/.env.local)
# =============================================================================

# Supabase Configuration (REQUIRED)
# Get these from your Supabase project dashboard at https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Server Configuration
PORT=3001
HOST=localhost
NODE_ENV=development

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Database Configuration
DB_PATH=./data/app.db

# Binance OAuth Configuration
BINANCE_OAUTH_CLIENT_ID=your_binance_oauth_client_id_here
BINANCE_OAUTH_CLIENT_SECRET=your_binance_oauth_client_secret_here
BINANCE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/binance/callback
BINANCE_API_BASE_URL=https://api.binance.com

# Plaid Integration Configuration
PLAID_ENV=sandbox # sandbox, development, or production
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here

# Logging Configuration
LOG_LEVEL=debug
LOG_SQL_QUERIES=true
LOG_REQUEST_BODIES=false
LOG_RESPONSE_BODIES=false
LOG_WEBSOCKET_MESSAGES=true
LOG_PRETTY=true
LOG_TIMESTAMP=true
LOG_COLORIZE=true

# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES (apps/frontend/.env.local)
# =============================================================================

# Supabase Configuration (REQUIRED)
# These must match your Supabase project (use the same values as backend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Configuration
VITE_API_URL=http://localhost:3001

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================

# 1. Create a Supabase project at https://supabase.com
# 2. Enable Email/Password authentication in Supabase Dashboard
# 3. Copy your project URL and keys from Supabase Dashboard > Settings > API
# 4. Replace the placeholder values above with your actual Supabase credentials
# 5. Copy this file to the appropriate locations:
#    - cp apps/backend/.env.example apps/backend/.env.local
#    - cp apps/frontend/.env.example apps/frontend/.env.local
# 6. Edit the .env.local files with your actual values

# =============================================================================
# SECURITY NOTES
# =============================================================================

# - Never commit .env.local files to version control
# - The .env.example files are safe to commit (no actual secrets)
# - SUPABASE_ANON_KEY is safe for frontend use (designed to be public)
# - SUPABASE_SERVICE_ROLE_KEY should only be used on the backend (never expose to frontend)
# - All environment variables are validated at startup - app will fail if required vars are missing

# =============================================================================
# ENCRYPTION CONFIGURATION (Backend only)
# =============================================================================

# Optional: 32-byte hex string (64 characters) for AES-256-GCM encryption
# Generate with: openssl rand -hex 32
# If not set, sensitive data (API keys, OAuth tokens) will be stored in plain text
# SECURITY NOTE: Plain text storage is acceptable for development/debugging,
# but encryption is strongly recommended for production environments
# ENCRYPTION_KEY=
