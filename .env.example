# Scani environment variables — single source of truth for local dev.
#
# Quick start:
#   cp .env.example .env
#   bun run dev:stack
#   open http://localhost:5173
#
# `bun run dev:stack` runs scripts/sync-env.ts (which generates per-app
# .env files from this root file) then boots the full docker compose stack.
# With the defaults below the stack is completely self-contained — no
# external service credentials are needed.
# Values marked "API key" unlock external features (screenshot parsing,
# EVM wallet sync, premium pricing); auth, holdings, FX pricing, and
# screenshot storage (via local MinIO) all work without any API key.
#
# The same variable set powers three deployment tiers:
#   Tier 1 — fully self-hosted: bun run dev:stack (self-hosts the data-provider)
#   Tier 2 — self-hosted app + a hosted data-provider: point
#           SCANI_CLOUD_URL at the hosted endpoint with an issued API key
#   Tier 3 — a fully-hosted deployment
# =============================================================================

# -----------------------------------------------------------------------------
# CORE — required for backend + worker to boot
# -----------------------------------------------------------------------------
NODE_ENV=development

# Postgres + Redis — host-side ports from docker-compose.yml infra services.
# For docker compose --profile full, the service-to-service URLs are set
# inside the compose file itself; these defaults are for `bun dev` on host.
DATABASE_URL=postgres://scani:scani@localhost:5433/scani?sslmode=disable
REDIS_URL=redis://localhost:6380

# Postgres connection-pool size. Defaults to 20, which matches a direct
# endpoint. Behind a connection pooler (e.g. PgBouncer, or a `?pgbouncer=true`
# URL) the per-app budget is far smaller — set this to 5 or so to avoid
# exhausting the pooler. The backend prints a loud warning at boot when it
# detects a pooled URL with the default pool size.
# POSTGRES_POOL_MAX=20

# Backend HTTP server (used by `bun dev:api` — docker uses 8080 inside
# the container and maps it to :3001 on the host).
PORT=3001
HOST=localhost

# Public URLs. Must match what the browser actually sees. FRONTEND_URL is
# used for CORS + Better-Auth cookie scope; BACKEND_URL is embedded in
# magic-link emails.
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# Better-Auth session signing. 32+ chars. Generate with `openssl rand -hex 32`.
# Rotating this invalidates every active session.
BETTER_AUTH_SECRET=dev_secret_change_me_this_is_not_production_safe

# AES-256-GCM key that encrypts integration credentials at rest. 32 hex chars.
# MUST match the worker's ENCRYPTION_KEY byte-for-byte — otherwise the worker
# cannot decrypt what the backend wrote, and every import silently fails.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# HMAC secret for operator tooling → api requests (BullMQ retry/remove,
# DLQ replay). Any client calling the HMAC-gated job endpoints must sign
# with this same secret.
JOBS_HMAC_SECRET=dev_jobs_hmac_change_me_not_prod_safe

# Shared secret for the screenshot-bot sign-in endpoint
# (POST /api/auth/screenshot-bot/sign-in). A caller sends this as a bearer
# token; the api then mints a Better-Auth session for the single
# allow-listed screenshots user. Required in prod, optional in dev.
SCREENSHOT_BOT_SECRET=dev_screenshot_bot_change_me_not_prod_safe_min_32_chars

# Pepper used by @scani/logging to one-way hash user/tenant/account IDs in
# structured logs. The pseudonymize helper refuses to import under
# NODE_ENV=production without this set (≥16 chars), so missing-pepper is
# a hard boot failure in prod instead of a silent UUID leak to the
# log aggregator. Dev/test leaves it unset and logs raw IDs for
# debuggability.
# WARNING: with LOG_ID_PEPPER unset, user/tenant/account IDs appear in
# plaintext in dev, test and local container logs — keep those logs off
# shared sinks. CI/staging/prod must always have a pepper set.
# Generate with `openssl rand -hex 32`.
LOG_ID_PEPPER=

# -----------------------------------------------------------------------------
# EMAIL — magic-link delivery
# -----------------------------------------------------------------------------
# Local dev uses Mailpit (docker-compose service). Open http://localhost:8026
# to view emails the backend sends. In production, set either SMTP_URL for
# any SMTP server, or FASTMAIL_API_TOKEN to send over JMAP.
SMTP_URL=smtp://localhost:1026
SMTP_FROM=no-reply@scani.local
# FASTMAIL_API_TOKEN=fmu1-...   # takes precedence over SMTP_URL when set

# -----------------------------------------------------------------------------
# OBJECT STORAGE — S3-compatible (MinIO locally, any S3-compatible store in prod)
# -----------------------------------------------------------------------------
# In local dev the compose stack runs a MinIO container with the creds below.
# S3_ENDPOINT is the server-side URL (what backend/worker talk to); docker
# compose overrides this with http://minio:9000 inside the container network.
# S3_PUBLIC_ENDPOINT is baked into presigned URLs, so the browser can reach
# the bucket — for local dev that's http://localhost:9000.
#
# For production, set S3_ENDPOINT to your S3-compatible provider's endpoint.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=job-uploads-dev
# Region. Defaults to "auto" (works for R2 + MinIO). Set explicitly for
# AWS S3 (e.g. us-east-1) — the AWS SDK signs requests with it.
# S3_REGION=auto

# -----------------------------------------------------------------------------
# LOGGING (owned by @scani/logging)
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_SQL_QUERIES=false
# Pretty-print extras. Defaults: on in dev (LOG_PRETTY=true), off in prod.
# LOG_COLORIZE=true
# LOG_TIMESTAMP=true
# Debug-only request/response body logging. The logger REFUSES to start with
# either set to "true" under NODE_ENV=production (prevents accidental
# PII leakage to log aggregators). Dev/test only.
# LOG_REQUEST_BODIES=false
# LOG_RESPONSE_BODIES=false
# WebSocket frame logging. On by default; turn off for very chatty SSE
# workloads.
# LOG_WEBSOCKET_MESSAGES=true

# -----------------------------------------------------------------------------
# WORKER (apps/backend/worker)
# -----------------------------------------------------------------------------
# Max concurrent BullMQ jobs per worker replica. Default 4 — bump for
# beefier hosts or large backfills.
# WORKER_CONCURRENCY=4
# Which AI provider the worker picks first for screenshot-parse +
# token-identity. Falls back through the list if a provider is missing
# credentials.
# AI_DEFAULT_PROVIDER=openai

# -----------------------------------------------------------------------------
# FRONTEND (Vite — values are baked into the SPA bundle at build time)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3001
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENABLED=false

# -----------------------------------------------------------------------------
# DATA-PROVIDER (apps/backend/data-provider) — where all 3rd-party calls terminate
# -----------------------------------------------------------------------------
# Tier 1 / self-hosted: bun run dev:stack spins up the `data-provider`
# container locally; these defaults point backend + worker at it.
# Tier 2/3:             set SCANI_CLOUD_URL to a hosted data-provider
#                       endpoint and SCANI_CLOUD_API_KEY to the issued key.
SCANI_CLOUD_URL=http://localhost:8082
SCANI_CLOUD_API_KEY=dev_data_provider_key_change_me_not_prod_safe
# The data-provider itself validates its inbound bearer against this env
# var. In single-tenant mode it's the same value as SCANI_CLOUD_API_KEY.
DATA_PROVIDER_API_KEY=dev_data_provider_key_change_me_not_prod_safe

# -----------------------------------------------------------------------------
# CLOUD MANAGEMENT — Tier 2/3 only (ignored in single-tenant mode)
# -----------------------------------------------------------------------------
# Set CLOUD_MANAGEMENT_ENABLED=true on a hosted data-provider to turn on
# DB-backed cloud API keys, Better-Auth cookie sessions for the management
# console, and Postgres-backed per-request metering (`cloud_usage_events`).
# Requires DATABASE_URL + BETTER_AUTH_URL + BETTER_AUTH_SECRET.
# CLOUD_MANAGEMENT_ENABLED=false
# BETTER_AUTH_URL=https://your-host.example.com
# CLOUD_FRONTEND_ORIGIN=https://your-host.example.com

# -----------------------------------------------------------------------------
# PROVIDER API KEYS — read by the data-provider
# -----------------------------------------------------------------------------
# In Tier 2/3 these live on the hosted data-provider and backend +
# worker don't need them at all. In Tier 1 set them here so the local
# data-provider container picks them up via scripts/sync-env.ts.
# Fiat/FX pricing uses exchangerate-api.com (no key). Crypto pricing without
# a CoinGecko key falls back to the public tier (rate-limited).
# COINGECKO_API_KEY=
# FINNHUB_API_KEY=

# OpenAI (screenshot parsing). Without a key, screenshot import is disabled.
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o

# Optional token-identity assists (used when CoinGecko misses on a token).
# PERPLEXITY_API_KEY=
# DEEPSEEK_API_KEY=

# Google Sheets — manual-asset pricing fallback. Both required if used.
# GOOGLE_SHEETS_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY=  # base64-encoded service-account JSON

# Blockchain explorers — EVM + Solana wallet-balance sync.
# Etherscan's single V2 key covers all EVM chains (Polygon, Arbitrum, …).
# ETHERSCAN_API_KEY=
# HELIUS_API_KEY=

# Binance OAuth — exchange connection flow.
# BINANCE_OAUTH_CLIENT_ID=
# BINANCE_OAUTH_CLIENT_SECRET=
# BINANCE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/binance/callback

# -----------------------------------------------------------------------------
# CROSS-SUBDOMAIN COOKIES (production only)
# -----------------------------------------------------------------------------
# Set to ".<your-domain>" so the session cookie minted on api.<domain>
# reaches app.<domain>. Leave unset in dev.
# COOKIE_DOMAIN=.your-domain.example.com

# -----------------------------------------------------------------------------
# SENTRY (optional — error tracking)
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=  # release tag for source-map upload + per-release dashboards

# -----------------------------------------------------------------------------
# DOCKER-COMPOSE.PROD.YML — runtime knobs read by the compose file itself
# -----------------------------------------------------------------------------
# Pin the image tag for reproducible deploys (defaults to "latest").
# SCANI_IMAGE_TAG=1.2.3
# Host port for the frontend-app container (the only externally-reachable
# service). Default 8080.
# FRONTEND_PORT=8080
# Inside the prod frontend-app image, nginx reverse-proxies /api/* →
# ${API_UPSTREAM}. Default reaches the api container on the compose
# network. Override when running frontend-app outside compose.
# API_UPSTREAM=http://api:3001
