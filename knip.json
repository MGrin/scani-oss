{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "apps/backend": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@sentry/node"]
    },
    "apps/cron": {
      "project": ["src/**/*.ts"]
    },
    "apps/frontendV2": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/landing": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/worker": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@sentry/node"]
    },
    "packages/ai-providers": {
      "project": ["src/**/*.ts"]
    },
    "packages/config": {
      "project": ["src/**/*.ts"]
    },
    "packages/db": {
      "project": ["src/**/*.ts"]
    },
    "packages/domain": {
      "project": ["src/**/*.ts"]
    },
    "packages/email": {
      "project": ["src/**/*.ts"]
    },
    "packages/integrations": {
      "entry": ["src/IntegrationManager.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/logging": {
      "project": ["src/**/*.ts"]
    },
    "packages/pricing-providers": {
      "project": ["src/**/*.ts"]
    },
    "packages/queue": {
      "project": ["src/**/*.ts"]
    },
    "packages/rate-limiter": {
      "project": ["src/**/*.ts"]
    },
    "packages/realtime": {
      "project": ["src/**/*.ts"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    },
    "packages/storage": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": ["**/*.test.ts"],
  "rules": {
    "exports": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off"
  }
}
