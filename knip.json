{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "apps/backend": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/cron": {
      "project": ["src/**/*.ts"]
    },
    "apps/frontendV2": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/landing": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/worker": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core": {
      "entry": ["src/scripts/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    },
    "packages/integrations": {
      "entry": ["src/IntegrationManager.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/rate-limiter": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": ["**/*.test.ts"],
  "rules": {
    "exports": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off"
  }
}
