## Core tRPC Setup

### 1. Create tRPC Client Instance

Create the typed tRPC client using the backend's AppRouter:

```typescript
// src/services/trpc/trpc.ts
import type { AppRouter } from "@scani/backend/types";
import { createTRPCReact } from "@trpc/react-query";

export const trpc = createTRPCReact<AppRouter>();
```

This gives you fully typed procedures across your entire app.

### 2. MMKV Persister for Cache Persistence

Create MMKV persister for automatic offline cache:

```typescript
// src/services/trpc/mmkvPersister.ts
import { MMKV } from "react-native-mmkv";
import type {
  PersistedClient,
  Persister,
} from "@tanstack/react-query-persist-client";

const storage = new MMKV({
  id: "trpc-cache",
});

export const mmkvPersister: Persister = {
  persistClient: async (client: PersistedClient) => {
    storage.set("queryCache", JSON.stringify(client));
  },
  restoreClient: async () => {
    const cached = storage.getString("queryCache");
    return cached ? JSON.parse(cached) : undefined;
  },
  removeClient: async () => {
    storage.delete("queryCache");
  },
};
```

### 3. tRPC Provider with Authentication

Create the provider that integrates with Supabase auth (see [Auth Guide](./506-react-native-supabase-authentication-and-storage.mdc) for Supabase setup):

```typescript
// src/services/trpc/trpcProvider.tsx
import { FC, ReactNode, useEffect, useState } from "react";
import { QueryClient } from "@tanstack/react-query";
import { PersistQueryClientProvider } from "@tanstack/react-query-persist-client";
import { httpBatchLink, TRPCClientError } from "@trpc/client";
import { useRouter } from "expo-router";
import { supabase } from "@/services/supabase/supabase";
import { trpc } from "./trpc";
import { mmkvPersister } from "./mmkvPersister";

interface TRPCProviderProps {
  children: ReactNode;
}

export const TRPCProvider: FC<TRPCProviderProps> = ({ children }) => {
  const router = useRouter();

  const [queryClient] = useState(
    () =>
      new QueryClient({
        defaultOptions: {
          queries: {
            gcTime: 1000 * 60 * 5,
            staleTime: 1000 * 60,
            refetchOnWindowFocus: true,
            refetchOnMount: false,
            refetchOnReconnect: true,
            networkMode: "online",
            retry: (failureCount, error) => {
              if (
                error instanceof TRPCClientError &&
                error.data?.code === "UNAUTHORIZED"
              ) {
                return false;
              }
              return failureCount < 3;
            },
          },
          mutations: {
            networkMode: "online",
            retry: (failureCount, error) => {
              if (
                error instanceof TRPCClientError &&
                error.data?.code === "UNAUTHORIZED"
              ) {
                return false;
              }
              return failureCount < 1;
            },
          },
        },
      })
  );

  // Global error handler for authentication issues
  useEffect(() => {
    const handleQueryError = (error: unknown) => {
      if (error instanceof TRPCClientError) {
        if (error.data?.code === "UNAUTHORIZED") {
          console.warn("[Auth] Unauthorized request detected");

          // Sign out and redirect to auth screen
          supabase.auth.signOut().catch(console.error);
          router.replace("/auth");
        }
      }
    };

    const unsubscribe = queryClient.getQueryCache().subscribe((event) => {
      if (event.type === "observerResultsUpdated" && event.query.state.error) {
        handleQueryError(event.query.state.error);
      }
    });

    return () => unsubscribe();
  }, [queryClient, router]);

  const [trpcClient] = useState(() =>
    trpc.createClient({
      links: [
        httpBatchLink({
          url: process.env.EXPO_PUBLIC_API_URL
            ? `${process.env.EXPO_PUBLIC_API_URL}/trpc`
            : "http://localhost:3001/trpc",

          // Get auth token from Supabase session
          async headers() {
            const {
              data: { session },
            } = await supabase.auth.getSession();

            return {
              authorization: session?.access_token
                ? `Bearer ${session.access_token}`
                : "",
            };
          },
        }),
      ],
    })
  );

  const persistOptions = {
    persister: mmkvPersister,
    maxAge: 1000 * 60 * 60 * 24,
    dehydrateOptions: {
      shouldDehydrateQuery: (query: any) => {
        return query.state.status === "success";
      },
    },
  };

  return (
    <trpc.Provider client={trpcClient} queryClient={queryClient}>
      <PersistQueryClientProvider
        client={queryClient}
        persistOptions={persistOptions}
        onSuccess={() => {
          queryClient.resumePausedMutations();
        }}
      >
        {children}
      </PersistQueryClientProvider>
    </trpc.Provider>
  );
};
```

**Note**: The `supabase` client is imported from `@/services/supabase/supabase`. See the [Authentication Guide](./506-react-native-supabase-authentication-and-storage.mdc) for the complete Supabase client setup with expo-secure-store.

### 4. Platform Integration (React Native)

Set up network and focus managers for React Native:

```typescript
// src/services/trpc/platformSetup.ts
import { useEffect } from "react";
import { AppState, Platform } from "react-native";
import type { AppStateStatus } from "react-native";
import { onlineManager, focusManager } from "@tanstack/react-query";
import * as Network from "expo-network";

/**
 * Set up online manager using expo-network
 */
export function setupOnlineManager() {
  onlineManager.setEventListener((setOnline) => {
    const subscription = Network.addNetworkStateListener((state) => {
      setOnline(!!state.isConnected);
    });
    return subscription.remove;
  });
}

/**
 * Hook to set up app focus manager
 */
export function useAppFocusManager() {
  useEffect(() => {
    const onAppStateChange = (status: AppStateStatus) => {
      if (Platform.OS !== "web") {
        focusManager.setFocused(status === "active");
      }
    };

    const subscription = AppState.addEventListener("change", onAppStateChange);
    return () => subscription.remove();
  }, []);
}
```

### 5. App Root Integration

Integrate the providers in your app root. **Important**: AuthProvider must wrap TRPCProvider:

```typescript
// src/app/_layout.tsx
import { Stack } from "expo-router";
import { AuthProvider } from "@/contexts/AuthContext";
import { TRPCProvider } from "@/services/trpc/trpcProvider";
import { setupOnlineManager, useAppFocusManager } from "@/services/trpc/platformSetup";

// Initialize online manager once
setupOnlineManager();

export default function RootLayout() {
  // Set up app focus manager
  useAppFocusManager();

  return (
    <AuthProvider>
      <TRPCProvider>
        <Stack />
      </TRPCProvider>
    </AuthProvider>
  );
}
```

**Note**: See the [Authentication Guide](./506-react-native-supabase-authentication-and-storage.mdc) for AuthProvider implementation details.

## Using tRPC in Components

### Basic Query Usage

tRPC procedures are fully typed and autocompleted:

```typescript
// src/components/HoldingsList.tsx
import { FC } from "react"
import { View, Text, FlatList } from "react-native"
import { trpc } from "@/services/trpc/trpc"
import { useAppTheme } from "@/theme/context"
import type { ThemedStyle } from "@/theme/types"
import { LoadingSpinner } from "./LoadingSpinner"
import { ErrorView } from "./ErrorView"

export const HoldingsList: FC = () => {
  const { themed } = useAppTheme()

  // Fully typed query - no manual query keys needed!
  const { data, isLoading, isError, error, refetch } = trpc.holdings.getWithDetails.useQuery()

  if (isLoading) {
    return <LoadingSpinner />
  }

  if (isError) {
    return <ErrorView error={error} onRetry={refetch} />
  }

  return (
    <FlatList
      data={data}
      renderItem={({ item }) => (
        <View style={themed($item)}>
          <Text style={themed($name)}>{item.token?.name}</Text>
          <Text style={themed($amount)}>{item.amount}</Text>
        </View>
      )}
      keyExtractor={(item) => item.id}
    />
  )
}

const $item: ThemedStyle<ViewStyle> = ({ spacing }) => ({
  padding: spacing.md,
})

const $name: ThemedStyle<TextStyle> = ({ spacing }) => ({
  marginBottom: spacing.sm,
})

const $amount: ThemedStyle<TextStyle> = ({ colors }) => ({
  color: colors.palette.neutral600,
})
```

### Query with Parameters

Pass parameters with full type safety:

```typescript
export const AccountDetail: FC<{ accountId: string }> = ({ accountId }) => {
  // Parameters are type-checked
  const { data: account } = trpc.accounts.getById.useQuery({ id: accountId })
  const { data: holdings } = trpc.accounts.getHoldings.useQuery({ accountId })

  return (
    <View>
      <Text>{account?.name}</Text>
      {/* Render holdings */}
    </View>
  )
}
```

### Conditional Queries

Use the `enabled` option to conditionally run queries:

```typescript
export const UserProfile: FC<{ userId?: string }> = ({ userId }) => {
  const { data: user } = trpc.users.getById.useQuery(
    { id: userId! },
    {
      enabled: !!userId, // Only run when userId is available
      staleTime: 1000 * 60 * 5, // Override default staleTime
    },
  )

  if (!userId) return null

  return <View>{/* Render user */}</View>
}
```

## Mutations

### Basic Mutation

Create and delete operations with cache invalidation:

```typescript
// src/components/HoldingActions.tsx
import { FC } from "react"
import { Button } from "@/components/ui/Button"
import { trpc } from "@/services/trpc/trpc"
import { useToast } from "@/hooks/useToast"

export const HoldingActions: FC<{ holdingId: string }> = ({ holdingId }) => {
  const { toast } = useToast()
  const utils = trpc.useUtils()

  const deleteHolding = trpc.holdings.delete.useMutation({
    onSuccess: () => {
      // Invalidate related queries to refetch data
      utils.holdings.getWithDetails.invalidate()
      utils.accounts.getByUserIdWithSummary.invalidate()
      utils.dashboard.getOverview.invalidate()

      toast({
        title: "common:success",
        description: "holdings:deleted",
      })
    },
    onError: (error) => {
      toast({
        title: "common:error",
        description: error.message,
        variant: "destructive",
      })
    },
  })

  return (
    <Button
      onPress={() => deleteHolding.mutate({ id: holdingId })}
      disabled={deleteHolding.isPending}
      tx="common:delete"
    />
  )
}
```

### Mutation with Update

Update operations with proper invalidation:

```typescript
export const UpdateHoldingForm: FC<{ holding: Holding }> = ({ holding }) => {
  const utils = trpc.useUtils()

  const updateHolding = trpc.holdings.update.useMutation({
    onSuccess: () => {
      // Invalidate all holding-related queries
      utils.holdings.getWithDetails.invalidate()
      utils.accounts.getHoldings.invalidate()
      utils.accounts.getByUserIdWithSummary.invalidate()
      utils.dashboard.getOverview.invalidate()
    },
  })

  const handleSubmit = (data: { balance: string; tokenId?: string }) => {
    updateHolding.mutate({
      id: holding.id,
      data,
    })
  }

  return <View>{/* Form UI */}</View>
}
```

### Optimistic Updates

Update UI immediately for better UX:

```typescript
export const useDeleteAccount = () => {
  const utils = trpc.useUtils();

  return trpc.accounts.delete.useMutation({
    onMutate: async (variables) => {
      // Cancel outgoing refetches
      await utils.accounts.getByUserIdWithSummary.cancel();

      // Snapshot previous value
      const previousAccounts = utils.accounts.getByUserIdWithSummary.getData();

      // Optimistically update cache
      utils.accounts.getByUserIdWithSummary.setData(undefined, (old) =>
        old?.filter((account) => account.id !== variables.id)
      );

      // Return context with snapshot
      return { previousAccounts };
    },
    onError: (_err, _variables, context) => {
      // Rollback on error
      if (context?.previousAccounts) {
        utils.accounts.getByUserIdWithSummary.setData(
          undefined,
          context.previousAccounts
        );
      }
    },
    onSettled: () => {
      // Always refetch after error or success
      utils.accounts.getByUserIdWithSummary.invalidate();
    },
  });
};
```

## Cache Management

### Invalidate Specific Procedure

Invalidate a single procedure to refetch:

```typescript
const utils = trpc.useUtils();

// Invalidate specific procedure
utils.holdings.getWithDetails.invalidate();
```

### Invalidate Entire Router

Invalidate all procedures in a router:

```typescript
// Invalidate all holdings procedures
utils.holdings.invalidate();
```

### Invalidate Multiple Related Queries

Common pattern after mutations:

```typescript
const createHolding = trpc.holdings.create.useMutation({
  onSuccess: () => {
    // Invalidate all affected queries
    utils.holdings.invalidate(); // All holding queries
    utils.accounts.getByUserIdWithSummary.invalidate();
    utils.dashboard.getOverview.invalidate();
  },
});
```

### Manual Cache Updates

Update cache directly without refetching:

```typescript
const updatePrice = trpc.holdings.updatePrice.useMutation({
  onSuccess: (data, variables) => {
    // Update specific holding in cache
    utils.holdings.getWithDetails.setData(undefined, (old) =>
      old?.map((holding) =>
        holding.id === variables.id
          ? { ...holding, currentPrice: data.price }
          : holding
      )
    );
  },
});
```

### Prefetch for Instant Navigation

Prefetch data before navigation:

```typescript
import { useRouter } from "expo-router"
import { trpc } from "@/services/trpc/trpc"

export const AccountListItem: FC<{ account: Account }> = ({ account }) => {
  const router = useRouter()
  const utils = trpc.useUtils()

  const handlePress = async () => {
    // Prefetch account details
    await utils.accounts.getById.prefetch({ id: account.id })

    // Navigate instantly with cached data
    router.push(`/accounts/${account.id}`)
  }

  return (
    <Pressable onPress={handlePress}>
      <Text>{account.name}</Text>
    </Pressable>
  )
}
```

## Loading States

### Skeleton Loader Component

Create skeleton that mirrors component structure:

```typescript
// src/components/HoldingsListSkeleton.tsx
import { FC, useEffect } from "react"
import { View } from "react-native"
import Animated, {
  useSharedValue,
  useAnimatedStyle,
  withRepeat,
  withTiming,
} from "react-native-reanimated"
import { useAppTheme } from "@/theme/context"
import type { ThemedStyle } from "@/theme/types"

export const HoldingsListSkeleton: FC = () => {
  const { themed, theme } = useAppTheme()
  const opacity = useSharedValue(0.3)

  useEffect(() => {
    opacity.value = withRepeat(withTiming(1, { duration: 1000 }), -1, true)
  }, [])

  const animatedStyle = useAnimatedStyle(() => ({
    opacity: opacity.value,
  }))

  return (
    <View style={themed($container)}>
      {[1, 2, 3, 4, 5].map((i) => (
        <Animated.View
          key={i}
          style={[
            themed($skeleton),
            animatedStyle,
            { backgroundColor: theme.colors.palette.neutral300 },
          ]}
        />
      ))}
    </View>
  )
}

const $container: ThemedStyle<ViewStyle> = ({ spacing }) => ({
  padding: spacing.md,
})

const $skeleton: ThemedStyle<ViewStyle> = ({ spacing }) => ({
  height: 80,
  borderRadius: 8,
  marginBottom: spacing.sm,
})
```

### Animated Spinner with Lucide

```typescript
// src/components/LoadingSpinner.tsx
import { FC, useEffect } from "react"
import { View } from "react-native"
import Animated, {
  useSharedValue,
  useAnimatedStyle,
  withRepeat,
  withTiming,
  Easing,
} from "react-native-reanimated"
import { Loader2 } from "lucide-react-native"
import { useAppTheme } from "@/theme/context"
import type { ThemedStyle } from "@/theme/types"

interface LoadingSpinnerProps {
  size?: number
  color?: string
}

export const LoadingSpinner: FC<LoadingSpinnerProps> = ({ size = 24, color }) => {
  const { themed, theme } = useAppTheme()
  const rotation = useSharedValue(0)

  useEffect(() => {
    rotation.value = withRepeat(
      withTiming(360, {
        duration: 1000,
        easing: Easing.linear,
      }),
      -1,
      false,
    )
  }, [])

  const animatedStyle = useAnimatedStyle(() => ({
    transform: [{ rotate: `${rotation.value}deg` }],
  }))

  return (
    <View style={themed($container)}>
      <Animated.View style={animatedStyle}>
        <Loader2 size={size} color={color ?? theme.colors.palette.primary500} />
      </Animated.View>
    </View>
  )
}

const $container: ThemedStyle<ViewStyle> = () => ({
  justifyContent: "center",
  alignItems: "center",
})
```

