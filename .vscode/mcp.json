{
  "servers": {
    "playwright": {
      "command": "bunx",
      "args": ["@playwright/mcp@latest"]
    },
    "render": {
      "url": "https://mcp.render.com/mcp",
      "headers": {
        "Authorization": "Bearer ${input:render_api_token}"
      },
      "type": "http"
    }
  },
  "inputs": [
    {
      "type": "promptString",
      "id": "render_api_token",
      "description": "Render MCP API Key",
      "password": true
    }
  ]
}
