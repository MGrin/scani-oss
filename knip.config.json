{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": ["apps/backend/src/index.ts"],
      "project": ["apps/backend/src/**/*.ts"]
    },
    "frontend": {
      "entry": ["apps/frontend/src/main.tsx"],
      "project": ["apps/frontend/src/**/*.{ts,tsx}"]
    },
    "shared": {
      "entry": ["packages/shared/src/index.ts"],
      "project": ["packages/shared/src/**/*.ts"]
    }
  },
  "ignore": ["**/__mocks__/**", "**/test/**", "**/*.test.ts", "**/*.test.tsx"]
}
